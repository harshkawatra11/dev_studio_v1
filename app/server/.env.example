PORT=4001
NODE_ENV=development

# Prisma database — SQLite for local dev, swap to postgresql:// for production
DATABASE_URL="file:./dev.db"

# JWT — generate strong random secrets for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_in_production_use_a_long_random_string
JWT_REFRESH_SECRET=change_me_in_production_use_a_different_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (optional — leave blank to disable email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="JobBoard <noreply@jobboard.dev>"

# CORS — set to your deployed frontend URL in production
CLIENT_URL=http://localhost:5173
