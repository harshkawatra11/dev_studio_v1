# Codex-Generated Sandbox Artifacts
# These belong in agent/cache/ only and are generated at runtime
sandbox/*.migration.sql
sandbox/*.model.js
sandbox/*.routes.js
sandbox/*.component.jsx
sandbox/client/src/generated/*.component.jsx
!sandbox/client/src/generated/.gitkeep

