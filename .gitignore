# ── Dependencies ────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build & Output ───────────────────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
out/
bin/
obj/
*.tsbuildinfo

# ── Vite / Bundler Cache ─────────────────────────────────────────────────────────
.vite/
**/.vite/
.cache/
**/.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

# ── Environment & Secrets ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── Databases (SQLite) ───────────────────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.tmp-logs/

# ── OS Files ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / Tooling ─────────────────────────────────────────────────────────────
.idea/
.vscode/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Codex-Generated Runtime Artifacts ────────────────────────────────────────────
# These are produced at runtime by Apply Slice; only the cache/ JSON ships in git
sandbox/*.migration.sql
sandbox/*.model.js
sandbox/*.routes.js
sandbox/*.component.jsx
sandbox/client/src/generated/*.component.jsx
!sandbox/client/src/generated/.gitkeep

# ── Claude Code / Session Transcripts ────────────────────────────────────────────
2026-*.txt
2025-*.txt
*-doctype-html*.txt

# ── Internal Planning Docs ────────────────────────────────────────────────────────
PRD_*.md

# ── Playwright / Test Artifacts ──────────────────────────────────────────────────
test-results/
playwright-report/
