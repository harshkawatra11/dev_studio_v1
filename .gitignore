# yarn.lock
# pnpm-lock.yaml

# Build & Output Directories
dist/
**/dist/
build/
**/build/
out/
bin/
obj/
*.tsbuildinfo

# Bundler & Cache Directories
.vite/
**/.vite/
.cache/
**/.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

# Environment and Secret Files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Local Databases (SQLite and runtime data)
*.db
*.db-journal
*.sqlite
*.sqlite3
**/sandbox/*.db
**/sandbox/*.db-journal

# Logs and Debug Output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.tmp-logs/

# Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor & Tooling Settings
.idea/
.vscode/
.claude/
*.suo
