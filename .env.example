# Workbench Studio v1.1 — environment variables
#
# Codex CLI manages its own auth (run `codex login`). No API key is needed
# anywhere in this repo.
#
# The only configurable env var is the Studio's pointer to the Agent Engine:

# Studio frontend → Agent base URL (optional; defaults to http://localhost:4000)
# Copy this file to studio/.env.local and adjust if you run the agent on a
# non-default host or port.
VITE_AGENT_URL=http://localhost:4000
